# Conexão Postgres (Neon ou local via docker-compose)
DATABASE_URL=

# Segredo para assinar JWTs (qualquer string longa)
JWT_SECRET=

# development | production
NODE_ENV=development

# Token do Vercel Blob (necessário só em produção, gerado no painel da Vercel
# em Storage → Blob → .env.local). Em dev, sem token, o upload usa disco local.
BLOB_READ_WRITE_TOKEN=

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model Planta {
    id        String   @id @default(uuid())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

    
model User {
    id        String   @id @default(uuid())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model AcademicPeriod {
    id        String   @id @default(uuid())
    name String
    semester String //Emun PRIMEIRO SEGUNDO
    start_date DateTime
    end_date DateTime
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

    
model AlunoTurma {
    id        String   @id @default(uuid())
    user_id   String
    user      User             @relation(fields: [user_id], references: [id])
    turma_id  String
    turma     Turma    @relation(fields: [turma_id], references: [id])
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

    
model Canteiro {
    id        String           @id @default(uuid())
    user_id   String
    user      User             @relation(fields: [user_id], references: [id])
    plant_id  String
    plant     PlantaForrageira @relation(fields: [plant_id], references: [id])
    name     String
    createdAt DateTime         @default(now())
    updatedAt DateTime         @updatedAt
}

    
model Checklist {
    id          String        @id @default(uuid())
    form_id     String
    form        Formulario    @relation(fields: [form_id], references: [id])
    template_id String
    template    PlantTemplate @relation(fields: [template_id], references:[id])
    checked     Boolean       @default(false)
    createdAt   DateTime      @default(now())
    updatedAt   DateTime      @updatedAt
}

    
model Formulario {
    id           String             @id @default(uuid())
    list_id      String
    list         ListaDeForumlarios @relation(fields: [list_id], references: [id])
    user_id      String
    user         User               @relation(fields: [user_id], references: [id])
    type:        String             //Enum SEMANAL DIARIO
    started_at:  DateTime
    ended_at:    DateTime
    observations String
    synced:      Boolean @default(false)
    createdAt    DateTime           @default(now())
    updatedAt    DateTime           @updatedAt
}

    
model Institution {
    id        String   @id @default(uuid())
    name      String
    users     User[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

    
model ListaDeFormularios {
    id          String   @id @default(uuid())
    canteiro_id String 
    canteiro    Canteiro @relation(fields: [canteiro_id], references: [id])
    plant_id    String
    plant       PlantaForrageira @relation(fields: [plant_id], references: [id])
    created_by  String
    user        User             @relation(fields: [created_by], references: [id])
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}

    
model Measurement {
    id          String   @id @default(uuid())
    form_id     String
    form        Formulario    @relation(fields: [form_id], references: [id])
    template_id String
    template    PlantTemplate @relation(fields: [template_id], references:[id])
    value       Float
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}

    
model Photo {
    id        String   @id @default(uuid())
    form_id   String
    form      Formulario    @relation(fields: [form_id], references: [id])
    url       String
    takenAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

    
model PlantaForrageira {
    id             String   @id @default(uuid())
    name          String
    category:      String //Enum GRAMINEA, LEGUMINOSA, CACTACEA, OUTRO
    description    String
    semester_focus String //Enum PRIMEIRO, SEGUNDO, AMBOS
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt
}

    
model PlantTemplate {
    id                String           @id @default(uuid())
    plant_id          String
    planta_forrageira PlantaForrageira @relation(fields: [plant_id], references: [id])
    field_name        String
    unit              String
    createdA          DateTime         @default(now())
    updatedA          DateTime         @updatedAt
}

    model RefreshToken {
  id          String   @id @default(uuid())
  token       String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  expiresAt   DateTime
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
}
model Relatorio {
    id        String   @id @default(uuid())
    user_id   String
    user      User             @relation(fields: [user_id], references: [id])
    canteiro_id String 
    canteiro    Canteiro @relation(fields: [canteiro_id], references: [id])
    list_id      String
    list         ListaDeForumlarios @relation(fields: [list_id], references: [id])
    status String //Enum RASCUNHO, SUBMETIDO, CORRIGIDO
    introduction String
    objective String
    development String
    final_thoughts String
    references String
    grade Float
    feedback String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    submited_at DateTime
}

    
model Turma {
    id        String   @id @default(uuid())
    institution_id String?
    institution Institution? @relation(fields: [institution_id], references: [id])
    period_id String
    period AcademicPeriod @relation(fields: [period_id], references:[id])
    name String
    created_by String
    user      User             @relation(fields: [created_by], references: [id])
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

    
model User {
    id             String   @id @default(uuid())
    name           String
    email          String   @unique
    password       String
    role           String   @default("aluno") //enum "aluno", "professor", "admin"
    institution_id String?
    institution Institution? @relation(fields: [institution_id], references: [id])
    refreshTokens RefreshToken[]
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt
}


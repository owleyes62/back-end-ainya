model UserCanteiro {
  user_id     String
  canteiro_id String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user     User     @relation(fields: [user_id], references: [id])
  canteiro Canteiro @relation(fields: [canteiro_id], references: [id])

  @@id([user_id, canteiro_id]) // chave primária composta
}
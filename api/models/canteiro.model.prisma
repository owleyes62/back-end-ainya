
model Canteiro {
    id        String           @id @default(uuid())
    plant_id  String
    plant     PlantaForrageira @relation(fields: [plant_id], references: [id])
    name     String
    createdAt DateTime         @default(now())
    updatedAt DateTime         @updatedAt

    listaDeFormularios ListaDeFormularios[]
    relatorios         Relatorio[]
    users              UserCanteiro[]
}

    

model Canteiro {
    id        String           @id @default(uuid())
    user_id   String
    user      User             @relation(fields: [user_id], references: [id])
    plant_id  String
    plant     PlantaForrageira @relation(fields: [plant_id], references: [id])
    name:     String
    createdAt DateTime         @default(now())
    updatedAt DateTime         @updatedAt
}

    
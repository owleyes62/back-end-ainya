
model PlantTemplate {
    id                String           @id @default(uuid())
    plant_id          String
    planta_forrageira PlantaForrageira @relation(fields: [plant_id], references: [id])
    field_name        String
    unit              String
    createdAt         DateTime         @default(now())
    updatedAt         DateTime         @updatedAt

    checklists   Checklist[]
    measurements Measurement[]
}

    
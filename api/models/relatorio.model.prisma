
model Relatorio {
    id        String   @id @default(uuid())
    user_id   String
    user      User             @relation(fields: [user_id], references: [id])
    canteiro_id String 
    canteiro    Canteiro @relation(fields: [canteiro_id], references: [id])
    list_id      String
    list         ListaDeFormularios @relation(fields: [list_id], references: [id])
    status String //Enum RASCUNHO, SUBMETIDO, CORRIGIDO
    introduction String
    objective String
    development String
    final_thoughts String
    references String
    grade Float
    feedback String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    submittedAt DateTime
}

    
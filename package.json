        "path": "^0.12.7",
        "pg": "^8.20.0",
        "serverless-http": "^4.0.0"
    },
    "scripts": {
        "start": "tsx api/index.ts",
        "dev": "tsx watch api/index.ts",
        "build": "tsc",
